# Copy to .env.local and never commit that file.

# Cloudflare
# Find the account ID with `bunx wrangler whoami`.
CLOUDFLARE_ACCOUNT_ID=

# User API Token for `bun run deploy:builds:setup`; do not use an Account API Token.
# Required permissions:
#   - Workers Builds Configuration: Edit
#   - Workers Scripts: Read
EDGE_EVER_BUILDS_API_TOKEN=

EDGE_EVER_WORKER_NAME=edgeever
EDGE_EVER_WORKERS_DEV=true

# Storage
EDGE_EVER_D1_DATABASE_NAME=edgeever
# Use the database_id returned by Cloudflare.
EDGE_EVER_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000
EDGE_EVER_KV_NAMESPACE_NAME=edgeever-resources
# Use the namespace ID returned by Cloudflare.
EDGE_EVER_KV_NAMESPACE_ID=00000000000000000000000000000000
EDGE_EVER_KV_PREVIEW_NAMESPACE_NAME=edgeever-resources-preview
EDGE_EVER_KV_PREVIEW_NAMESPACE_ID=00000000000000000000000000000000
# 750 MiB, leaving headroom below the account-wide Workers Free 1 GB KV limit.
EDGE_EVER_RESOURCE_STORAGE_LIMIT_BYTES=786432000
# Daily cleanup runs after KV Free quotas reset at 00:00 UTC.
EDGE_EVER_RESOURCE_GC_CRON=15 0 * * *
# Set only after confirming that the account has no Workers Paid subscription.
EDGE_EVER_WORKERS_FREE_CONFIRMED=false

# Authentication
# Initial login credentials; the password is uploaded as a Worker Secret.
EDGE_EVER_AUTH_USERNAME=admin
EDGE_EVER_AUTH_PASSWORD=admin123
# Allowed range: 1-400 days.
EDGE_EVER_SESSION_TTL_DAYS=400

# Demo mode
# Seeds sample content and periodically resets it; intended for public demos only.
EDGE_EVER_DEMO_MODE=false
# UTC Cron schedule, used only when demo mode is enabled.
EDGE_EVER_DEMO_RESET_CRON=0 19 * * *

# Routing
# Example: notes.example.com
EDGE_EVER_CUSTOM_DOMAIN=
# Optional full route pattern; otherwise the custom domain is used.
EDGE_EVER_ROUTE_PATTERN=

# Local frontend
VITE_API_BASE_URL=http://127.0.0.1:8787

# Multi-instance deployments
# Select remote instances per command, for example:
# EDGE_EVER_INSTANCE=prod bun run dev:remote
# Instance-specific `EDGE_EVER_<NAME>_*` values override the generic values above.
